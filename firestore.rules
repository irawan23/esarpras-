rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Common helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }
    
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.keys().size() >= 2 &&
             data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 256;
    }

    // Rules for User profiles
    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming()) && isValidId(userId);
      allow update: if isSignedIn() && (isOwner(userId) || isAdmin()) && isValidUser(incoming()) &&
                    incoming().uid == existing().uid &&
                    incoming().email == existing().email && (
                      incoming().diff(existing()).affectedKeys().hasOnly(['name', 'role']) ||
                      isAdmin()
                    );
      allow delete: if isSignedIn() && isAdmin();
    }

    // Rules for Settings
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isSignedIn() && isAdmin() && isValidId(settingId);
    }

    // Rules for admins collection
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Only configured via Cloud Console
    }
  }
}
