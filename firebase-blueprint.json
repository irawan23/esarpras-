{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile document",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "Setting": {
      "title": "Setting",
      "description": "School settings document",
      "type": "object",
      "properties": {
        "schoolName": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User documents"
    },
    "/settings/{settingId}": {
      "schema": "Setting",
      "description": "School configuration"
    }
  }
}
